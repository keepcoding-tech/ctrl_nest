<div class="alert alert-danger alert-dismissible">
  <button type="button" class="close" data-dismiss="alert" aria-hidden="true">
    &times;
  </button>
  <div>
    <b>
      <i class="icon fas fa-ban"></i>
      <%= $title %>
    </b>
    <div class="text-sm m-2">
      <%= $body %>
    </div>
  </div>
</div>
